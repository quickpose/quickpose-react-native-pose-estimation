{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react",
    "moduleResolution": "node",
    "target": "es2017",
    "lib": ["es2017"],
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "lib"
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "example-*"]
}
